msgstr "La stazione sembra essere fuori onda"

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:2343
msgid "%1 is not answering at any address the directory knows. It stays in your list — trying again in the background."
msgstr "%1 non risponde a nessun indirizzo noto alla directory. Resta nel tuo elenco — nuovi tentativi in background."

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:2413
msgid "Playing from a backup address"
msgstr "In riproduzione da un indirizzo di riserva"

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:2414
msgid "The station's saved address is not answering — playing the directory's closest match for now. Your saved address was kept."
msgstr "L'indirizzo salvato della stazione non risponde — per ora suona la corrispondenza più vicina della directory. L'indirizzo salvato è stato mantenuto."

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:2443
