msgstr "Registrazione interrotta (%1 catturato)"

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:4163
msgid "%1 — the file is much smaller than expected."
msgstr "%1 — il file è molto più piccolo del previsto."

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:4167
msgid "Recording failed"
msgstr "Registrazione non riuscita"

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:4168
msgid "The stream could not be captured."
msgstr "Impossibile catturare lo stream."

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:4252
