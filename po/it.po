msgstr "Il dispositivo non è riuscito a riprodurre questa stazione."

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:3594
#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:3667
msgid "the Bluetooth device"
msgstr "il dispositivo Bluetooth"

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:3593
msgid "Could not connect to %1"
msgstr "Impossibile connettersi a %1"

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:3595
msgid "Make sure the speaker is switched on and in range."
msgstr "Assicurati che l'altoparlante sia acceso e a portata."

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:3666
msgid "Could not pair with %1"
msgstr "Impossibile associare %1"

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:3668
msgid "Put the speaker in pairing mode (hold its Bluetooth button) and try again."
msgstr "Metti l'altoparlante in modalità associazione (tieni premuto il pulsante Bluetooth) e riprova."

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:3758
msgid "ffmpeg is not installed"
msgstr "ffmpeg non è installato"

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:3759
msgid "Install ffmpeg to record radio."
msgstr "Installa ffmpeg per registrare la radio."

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:3762
msgid "Recording saved ✓ (%1)"
msgstr "Registrazione salvata ✓ (%1)"

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:3766
msgid "Recording interrupted (%1 captured)"
msgstr "Registrazione interrotta (%1 catturato)"

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:3768
msgid "%1 — the file is much smaller than expected."
msgstr "%1 — il file è molto più piccolo del previsto."

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:3772
msgid "Recording failed"
msgstr "Registrazione non riuscita"

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:3773
msgid "The stream could not be captured."
msgstr "Impossibile catturare lo stream."

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:3814
msgid "Downloading again without the cover"
msgstr "Nuovo scaricamento senza copertina"

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:3815
msgid "Embedding tags needs the python-mutagen package — install it to get covers in your files."
msgstr "Per incorporare i tag serve il pacchetto python-mutagen — installalo per avere le copertine nei file."

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:3823
msgid "yt-dlp is not installed"
msgstr "yt-dlp non è installato"

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:3824
msgid "Install yt-dlp (and ffmpeg) to download tracks."
msgstr "Installa yt-dlp (e ffmpeg) per scaricare i brani."

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:3827
msgid "Track downloaded ✓"
msgstr "Brano scaricato ✓"

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:3828
msgid "Saved to: %1"
msgstr "Salvato in: %1"

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:3831
msgid "Download failed"
msgstr "Download non riuscito"

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:3832
msgid "Unknown error"
msgstr "Errore sconosciuto"

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:4125
msgid "Audio output changed"
msgstr "Uscita audio cambiata"

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:4126
msgid "The chosen output device disappeared — using the system default instead."
msgstr "Il dispositivo di uscita scelto è scomparso — viene usata l'uscita predefinita di sistema."

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/MediaListItem.qml:261
msgid "Move up"
msgstr "Sposta su"

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/MediaListItem.qml:285
msgid "Move down"
msgstr "Sposta giù"

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/MediaListItem.qml:317
msgid "Click again to confirm removal"
msgstr "Fai clic di nuovo per confermare la rimozione"

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/MediaListItem.qml:318
msgid "Remove station from list"
msgstr "Rimuovi la stazione dall'elenco"

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/SyncEngine.qml:189
msgid "Could not combine the outputs"
msgstr "Impossibile combinare le uscite"

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/SyncEngine.qml:190
msgid "pactl refused to create the combined output."
msgstr "pactl ha rifiutato di creare l'uscita combinata."

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/SyncEngine.qml:368
msgid "The Bluetooth speaker trails by %1 ms, and every speaker's loudness was matched at the microphone — all set and remembered."
msgstr "L'altoparlante Bluetooth è in ritardo di %1 ms e il volume di tutti gli altoparlanti è stato uniformato al microfono — tutto impostato e memorizzato."

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/SyncEngine.qml:369
msgid "The Bluetooth speaker trails by %1 ms — the delay is set and remembered for this device."
msgstr "L'altoparlante Bluetooth ritarda di %1 ms — il ritardo è impostato e memorizzato per questo dispositivo."

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/SyncEngine.qml:371
msgid "Balance levels set earlier were replaced by the measured ones."
msgstr "I livelli di bilanciamento impostati in precedenza sono stati sostituiti da quelli misurati."

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/SyncEngine.qml:379
msgid "The microphone clipped on %1 — that balance was left unchanged; lower the speaker's volume and calibrate again."
msgstr "Il microfono è andato in saturazione su %1 — quel bilanciamento è rimasto invariato; abbassa il volume del diffusore e ricalibra."

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/SyncEngine.qml:380
msgid "Speakers calibrated"
msgstr "Altoparlanti calibrati"

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/SyncEngine.qml:383
msgid "Calibration did not succeed"
msgstr "La calibrazione non è riuscita"

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/SyncEngine.qml:384
msgid "Make sure the microphone is not covered and both speakers can be heard, then try again."
msgstr "Assicurati che il microfono non sia coperto e che entrambi gli altoparlanti si sentano, poi riprova."

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/SyncEngine.qml:434
msgid "The speakers were %1 ms apart — adjusted from the measurement, checking once more."
msgstr "I diffusori erano a %1 ms di distanza — regolato in base alla misura, ricontrollo in corso."

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/SyncEngine.qml:449
msgid "A speaker's route was stuck %1 ms behind — flushed it, checking once more."
msgstr "Il percorso di un diffusore era bloccato di %1 ms — svuotato, ricontrollo in corso."

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/SyncEngine.qml:457
#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/SyncEngine.qml:465
#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/SyncEngine.qml:475
#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/SyncEngine.qml:488
msgid "Sync check"
msgstr "Controllo sincronizzazione"

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/SyncEngine.qml:466
msgid "The room was not quiet enough to verify — pause other audio and calibrate once more."
msgstr "La stanza non era abbastanza silenziosa per la verifica — metti in pausa l'altro audio e ricalibra."

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/SyncEngine.qml:476
msgid "Could not hear %1 during the check — the speaker may be muted or off. The calibration was kept."
msgstr "%1 non si è sentito durante il controllo — il diffusore potrebbe essere muto o spento. La calibrazione è stata mantenuta."

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/SyncEngine.qml:484
msgid "Sync verified"
msgstr "Sincronizzazione verificata"

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/SyncEngine.qml:485
msgid "Every speaker arrives within %1 ms at the microphone — in step to the ear."
msgstr "Ogni diffusore arriva al microfono entro %1 ms — per l'orecchio, in perfetto passo."

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/SyncEngine.qml:489
msgid "The speakers still arrive %1 ms apart. Calibrate once more, or nudge the delay slider."
msgstr "I diffusori arrivano ancora a %1 ms di distanza. Ricalibra o ritocca il cursore del ritardo."

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/SyncEngine.qml:1069
msgid "Two rounds of clicks with a quiet check between them — about two minutes in total. The music stays silent until the check finishes."
msgstr "Due serie di clic con una verifica silenziosa in mezzo — circa due minuti in totale. La musica resta muta finché la verifica non termina."

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/SyncEngine.qml:1071
msgid "Skipped (empty jack): %1."
msgstr "Saltato (presa vuota): %1."

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/SyncEngine.qml:1072
msgid "Calibration started"
msgstr "Calibrazione avviata"

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/SyncEngine.qml:1115
msgid "All local outputs (On Air)"
msgstr "Tutte le uscite locali (On Air)"

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/SyncEngine.qml:1621
msgid "%1 did not join the sync"
msgstr "%1 non si è unito alla sincronizzazione"

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/SyncEngine.qml:1623
msgid "The speaker is connected but could not be pulled into the group — switch the sync off and on to rebuild it."
msgstr "L'altoparlante è connesso, ma non è stato possibile inserirlo nel gruppo — disattiva e riattiva la sincronizzazione."

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/SyncEngine.qml:1624
msgid "The speaker is connected but its audio output never appeared — switch the speaker off and on, then connect it again."
msgstr "L'altoparlante è connesso, ma la sua uscita audio non è mai apparsa — spegni e riaccendi l'altoparlante, poi riconnettilo."

