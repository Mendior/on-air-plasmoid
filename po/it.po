msgstr "Sveglia mancata"

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:1083
msgid "%1 was set for %2 — the computer was off or asleep at that time."
msgstr "%1 era impostata per le %2 — il computer era spento o in sospensione in quel momento."

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:1117
#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:1174
#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:1212
#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:1215
