msgstr "%1 scadeva alla stessa ora — al suo posto suona %2."

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:1216
msgid "The station could not start — playing the built-in tone instead."
msgstr "La stazione non è partita — viene riprodotto il tono integrato."

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:1707
