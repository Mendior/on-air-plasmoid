msgid "ffmpeg is not installed"
msgstr "ffmpeg non è installato"

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:4154
msgid "Install ffmpeg to record radio."
msgstr "Installa ffmpeg per registrare la radio."

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:4157
msgid "Recording saved ✓ (%1)"
msgstr "Registrazione salvata ✓ (%1)"

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:4161
