#~ msgstr "Ascolto dei clic…"

#~ msgid "This speaker's share of the volume — the balance follows every master move and is remembered for the device."
#~ msgstr "La quota di questo altoparlante nel volume — il bilanciamento segue ogni movimento del cursore principale e viene ricordato per il dispositivo."

#~ msgid "Volume: "
#~ msgstr "Volume: "
