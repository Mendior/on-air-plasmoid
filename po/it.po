msgstr "Stazione trovata a un nuovo indirizzo"

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:2444
msgid "%1 moved — the new address was saved to your list."
msgstr "%1 si è trasferita — il nuovo indirizzo è stato salvato nella tua lista."

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:3497
msgid "Casting needs python-chromecast"
msgstr "La trasmissione richiede python-chromecast"

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:3498
msgid "Install the python-chromecast package to cast to your devices."
msgstr "Installa il pacchetto python-chromecast per trasmettere ai tuoi dispositivi."

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:3501
msgid "the device"
msgstr "il dispositivo"

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:3501
