msgid "Download failed"
msgstr "Pobieranie nie powiodło się"

#: ⁨/home/egon/minu
#: projektid/onair-plasmoid/package/contents/ui/main.qml⁩:4270
msgid "Unknown error"
msgstr "Nieznany błąd"

#: ⁨/home/egon/minu
#: projektid/onair-plasmoid/package/contents/ui/main.qml⁩:4546
