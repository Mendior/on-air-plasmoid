msgid "%1 (nothing plugged in)"
msgstr "%1 (nic nie podłączono)"

#: package/contents/ui/FullRepresentation.qml:5009
msgid "Balance of %1"
msgstr "Balans %1"

#: package/contents/ui/FullRepresentation.qml:5018
msgid "This speaker's share of the volume — the balance follows every master move and is remembered for the device. It scales only what this widget plays; the per-device volume in the system's audio settings is a separate, untouched layer — which is why those numbers differ from these sliders."
msgstr "Udział tego głośnika w głośności — balans podąża za każdym ruchem głównego suwaka i jest zapamiętywany dla urządzenia. Działa tylko na to, co odtwarza ten widżet; głośność urządzenia w ustawieniach dźwięku systemu to osobna, nietknięta warstwa — dlatego tamte liczby różnią się od tych suwaków."

#: package/contents/ui/FullRepresentation.qml:5035
msgctxt "compact: speaker plays the left channel"
msgid "L"
msgstr "L"

#: package/contents/ui/FullRepresentation.qml:5036
msgctxt "compact: speaker plays the right channel"
