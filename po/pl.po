msgstr "Nagrywanie nie powiodło się"

#: ⁨/home/egon/minu
#: projektid/onair-plasmoid/package/contents/ui/main.qml⁩:4168
msgid "The stream could not be captured."
msgstr "Nie udało się przechwycić strumienia."

#: ⁨/home/egon/minu
#: projektid/onair-plasmoid/package/contents/ui/main.qml⁩:4252
msgid "Downloading again without the cover"
msgstr "Pobieranie ponownie bez okładki"

#: ⁨/home/egon/minu
#: projektid/onair-plasmoid/package/contents/ui/main.qml⁩:4253
msgid ""
"Embedding tags needs the python-mutagen package — install it to get covers "
"in your files."
msgstr ""
"Do osadzania znaczników potrzebny jest pakiet python-mutagen — zainstaluj "
"go, aby mieć okładki w plikach."

#: ⁨/home/egon/minu
#: projektid/onair-plasmoid/package/contents/ui/main.qml⁩:4261
msgid "yt-dlp is not installed"
msgstr "yt-dlp nie jest zainstalowany"

#: ⁨/home/egon/minu
#: projektid/onair-plasmoid/package/contents/ui/main.qml⁩:4262
msgid "Install yt-dlp (and ffmpeg) to download tracks."
msgstr "Zainstaluj yt-dlp (i ffmpeg), aby pobierać utwory."

#: ⁨/home/egon/minu
#: projektid/onair-plasmoid/package/contents/ui/main.qml⁩:4265
msgid "Track downloaded ✓"
msgstr "Utwór pobrany ✓"

#: ⁨/home/egon/minu
