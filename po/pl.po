msgid "Install ffmpeg to record radio."
msgstr "Zainstaluj ffmpeg, aby nagrywać radio."

#: package/contents/ui/main.qml:4259
msgid "Recording saved ✓ (%1)"
msgstr "Nagranie zapisane ✓ (%1)"

#: package/contents/ui/main.qml:4263
msgid "Recording interrupted (%1 captured)"
msgstr "Nagranie przerwane (nagrano %1)"

#: package/contents/ui/main.qml:4265
msgid "%1 — the file is much smaller than expected."
msgstr "%1 — plik jest znacznie mniejszy niż oczekiwano."

#: package/contents/ui/main.qml:4269
msgid "Recording failed"
msgstr "Nagrywanie nie powiodło się"

#: package/contents/ui/main.qml:4270
msgid "The stream could not be captured."
msgstr "Nie udało się przechwycić strumienia."

#: package/contents/ui/main.qml:4354
msgid "Downloading again without the cover"
msgstr "Pobieranie ponownie bez okładki"

#: package/contents/ui/main.qml:4355
msgid "Embedding tags needs the python-mutagen package — install it to get covers in your files."
msgstr "Do osadzania znaczników potrzebny jest pakiet python-mutagen — zainstaluj go, aby mieć okładki w plikach."

#: package/contents/ui/main.qml:4363
msgid "yt-dlp is not installed"
msgstr "yt-dlp nie jest zainstalowany"

#: package/contents/ui/main.qml:4364
msgid "Install yt-dlp (and ffmpeg) to download tracks."
msgstr "Zainstaluj yt-dlp (i ffmpeg), aby pobierać utwory."

#: package/contents/ui/main.qml:4367
msgid "Track downloaded ✓"
msgstr "Utwór pobrany ✓"

#: package/contents/ui/main.qml:4368
msgid "Saved to: %1"
msgstr "Zapisano w: %1"

#: package/contents/ui/main.qml:4371
msgid "Download failed"
msgstr "Pobieranie nie powiodło się"

#: package/contents/ui/main.qml:4372
msgid "Unknown error"
msgstr "Nieznany błąd"

#: package/contents/ui/main.qml:4648
msgid "Audio output changed"
msgstr "Wyjście dźwięku zmienione"

#: package/contents/ui/main.qml:4649
msgid "The chosen output device disappeared — using the system default instead."
msgstr "Wybrane urządzenie wyjściowe zniknęło — używane jest domyślne wyjście systemowe."

#: package/contents/ui/MediaListItem.qml:261
msgid "Move up"
msgstr "Przesuń w górę"

#: package/contents/ui/MediaListItem.qml:285
msgid "Move down"
msgstr "Przesuń w dół"

#: package/contents/ui/MediaListItem.qml:317
msgid "Click again to confirm removal"
msgstr "Kliknij ponownie, aby potwierdzić usunięcie"

#: package/contents/ui/MediaListItem.qml:318
msgid "Remove station from list"
msgstr "Usuń stację z listy"

#: package/contents/ui/SyncEngine.qml:290
msgid "Could not combine the outputs"
msgstr "Nie udało się połączyć wyjść"

#: package/contents/ui/SyncEngine.qml:291
msgid "pactl refused to create the combined output."
msgstr "pactl odmówił utworzenia połączonego wyjścia."

#: package/contents/ui/SyncEngine.qml:557
msgid "The Bluetooth speaker trails by %1 ms, and every speaker's loudness was matched at the microphone — all set and remembered."
msgstr "Głośnik Bluetooth jest opóźniony o %1 ms, a głośność wszystkich głośników została wyrównana przy mikrofonie — wszystko ustawione i zapamiętane."

#: package/contents/ui/SyncEngine.qml:558
msgid "The Bluetooth speaker trails by %1 ms — the delay is set and remembered for this device."
msgstr "Głośnik Bluetooth spóźnia się o %1 ms — opóźnienie zostało ustawione i zapamiętane dla tego urządzenia."

#: package/contents/ui/SyncEngine.qml:560
msgid "Balance levels set earlier were replaced by the measured ones."
msgstr "Ustawione wcześniej poziomy balansu zastąpiono zmierzonymi."

#: package/contents/ui/SyncEngine.qml:568
msgid "The microphone clipped on %1 — that balance was left unchanged; lower the speaker's volume and calibrate again."
msgstr "Mikrofon przesterował na %1 — ten balans pozostał bez zmian; ścisz głośnik i skalibruj ponownie."

#: package/contents/ui/SyncEngine.qml:574
msgid "Measured with %1 — the default microphone stayed silent."
msgstr "Zmierzono mikrofonem %1 — domyślny mikrofon milczał."

#: package/contents/ui/SyncEngine.qml:575
msgid "Speakers calibrated"
msgstr "Głośniki skalibrowane"

#: package/contents/ui/SyncEngine.qml:584
#: package/contents/ui/SyncEngine.qml:620
msgid "Calibration did not succeed"
msgstr "Kalibracja się nie powiodła"

#: package/contents/ui/SyncEngine.qml:585
#: package/contents/ui/SyncEngine.qml:732
msgid "Every microphone delivered pure silence. A mic's own mute button is invisible to the system — check the light on the microphone itself, or set a working microphone as the default."
msgstr "Każdy mikrofon dostarczył czystą ciszę. Przycisk wyciszenia na samym mikrofonie jest niewidoczny dla systemu — sprawdź lampkę na mikrofonie albo ustaw działający mikrofon jako domyślny."

#: package/contents/ui/SyncEngine.qml:607
msgid "Calibration"
msgstr "Kalibracja"

#: package/contents/ui/SyncEngine.qml:608
msgid "The clicks were too quiet for this room — trying once more, louder."
msgstr "Kliknięcia były za ciche dla tego pomieszczenia — jeszcze jedna próba, głośniej."

#: package/contents/ui/SyncEngine.qml:621
msgid "Make sure the microphone is not covered and both speakers can be heard, then try again."
msgstr "Upewnij się, że mikrofon nie jest zasłonięty i słychać oba głośniki, po czym spróbuj ponownie."

#: package/contents/ui/SyncEngine.qml:677
msgid "The speakers were %1 ms apart — adjusted from the measurement, checking once more."
msgstr "Głośniki dzieliło %1 ms — skorygowano według pomiaru, trwa ponowna kontrola."

#: package/contents/ui/SyncEngine.qml:692
msgid "A speaker's route was stuck %1 ms behind — flushed it, checking once more."
msgstr "Trasa jednego z głośników utknęła %1 ms w tyle — opróżniono ją, trwa ponowna kontrola."

#: package/contents/ui/SyncEngine.qml:702
#: package/contents/ui/SyncEngine.qml:722
#: package/contents/ui/SyncEngine.qml:731
#: package/contents/ui/SyncEngine.qml:759
#: package/contents/ui/SyncEngine.qml:764
#: package/contents/ui/SyncEngine.qml:771
#: package/contents/ui/SyncEngine.qml:784
msgid "Sync check"
msgstr "Kontrola synchronizacji"

#: package/contents/ui/SyncEngine.qml:723
msgid "The room was not quiet enough to verify — pause other audio and calibrate once more."
msgstr "W pomieszczeniu nie było wystarczająco cicho, by zweryfikować — wstrzymaj inne dźwięki i skalibruj ponownie."

#: package/contents/ui/SyncEngine.qml:760
msgid "%1 stayed silent through both rounds — it was left out of the group. Tick it back in the speaker list any time."
msgstr "%1 milczał w obu rundach — został pominięty w grupie. Zaznacz go na liście głośników, kiedy zechcesz."

#: package/contents/ui/SyncEngine.qml:765
msgid "%1 made no sound the microphone could hear. If it stays silent on the next calibration too, it will be left out of the group."
msgstr "%1 nie wydał żadnego dźwięku słyszalnego dla mikrofonu. Jeśli pozostanie cichy także przy następnej kalibracji, zostanie wyłączony z grupy."

#: package/contents/ui/SyncEngine.qml:772
msgid "Could not hear %1 during the check — the speaker may be muted or off. The calibration was kept."
msgstr "Podczas kontroli nie było słychać %1 — głośnik może być wyciszony lub wyłączony. Kalibrację zachowano."

#: package/contents/ui/SyncEngine.qml:780
msgid "Sync verified"
msgstr "Synchronizacja potwierdzona"

#: package/contents/ui/SyncEngine.qml:781
msgid "Every speaker arrives within %1 ms at the microphone — in step to the ear."
msgstr "Każdy głośnik dociera do mikrofonu w granicach %1 ms — dla ucha w pełnym rytmie."

#: package/contents/ui/SyncEngine.qml:785
msgid "The speakers still arrive %1 ms apart. Calibrate once more, or nudge the delay slider."
msgstr "Głośniki wciąż docierają w odstępie %1 ms. Skalibruj ponownie albo przesuń suwak opóźnienia."

#: package/contents/ui/SyncEngine.qml:1412
msgid "Two rounds of clicks with a quiet check between them — about two minutes in total. The music stays silent until the check finishes."
msgstr "Dwie rundy kliknięć z cichym sprawdzeniem pomiędzy — łącznie około dwóch minut. Muzyka pozostaje wyciszona do końca sprawdzenia."

#: package/contents/ui/SyncEngine.qml:1414
msgid "Skipped (empty jack): %1."
msgstr "Pominięto (puste gniazdo): %1."

#: package/contents/ui/SyncEngine.qml:1415
msgid "Calibration started"
msgstr "Rozpoczęto kalibrację"

#: package/contents/ui/SyncEngine.qml:1476
msgid "All local outputs (On Air)"
msgstr "Wszystkie lokalne wyjścia (On Air)"

#: package/contents/ui/SyncEngine.qml:2121
msgid "%1 did not join the sync"
msgstr "%1 nie dołączył do synchronizacji"

#: package/contents/ui/SyncEngine.qml:2123
msgid "The speaker is connected but could not be pulled into the group — switch the sync off and on to rebuild it."
msgstr "Głośnik jest połączony, ale nie udało się go włączyć do grupy — wyłącz i włącz synchronizację."

#: package/contents/ui/SyncEngine.qml:2124
msgid "The speaker is connected but its audio output never appeared — switch the speaker off and on, then connect it again."
msgstr "Głośnik jest połączony, ale jego wyjście audio nigdy się nie pojawiło — wyłącz i włącz głośnik, a następnie połącz go ponownie."

