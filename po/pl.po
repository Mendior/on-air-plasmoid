#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/FullRepresentation.qml:2694
#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/FullRepresentation.qml:2701
msgid "Sync fine-tune"
msgstr "Dostrajanie synchronizacji"

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/FullRepresentation.qml:2711
msgid "If the Bluetooth speaker still trails the wired ones, raise this until they play together."
msgstr "Jeśli głośnik Bluetooth wciąż jest opóźniony względem przewodowych, zwiększaj to, aż zagrają razem."

