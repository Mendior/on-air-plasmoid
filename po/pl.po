msgstr "Nie udało się sparować z %1"

#: ⁨/home/egon/minu
#: projektid/onair-plasmoid/package/contents/ui/main.qml⁩:4063
msgid ""
"Put the speaker in pairing mode (hold its Bluetooth button) and try again."
msgstr ""
"Przełącz głośnik w tryb parowania (przytrzymaj przycisk Bluetooth) i spróbuj"
" ponownie."

#: ⁨/home/egon/minu
#: projektid/onair-plasmoid/package/contents/ui/main.qml⁩:4153
msgid "ffmpeg is not installed"
msgstr "ffmpeg nie jest zainstalowany"

#: ⁨/home/egon/minu
#: projektid/onair-plasmoid/package/contents/ui/main.qml⁩:4154
