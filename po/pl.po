#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/FullRepresentation.qml:2750
msgid "Listening to the clicks…"
msgstr "Nasłuchiwanie kliknięć…"

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/FullRepresentation.qml:2780
msgid "%1 plays in the group"
msgstr "%1 gra w grupie"

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/FullRepresentation.qml:2793
msgid "Whether this speaker plays in the group — untick to leave it out without disconnecting it. Remembered for the device."
