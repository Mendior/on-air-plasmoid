msgstr "Zainstaluj ffmpeg, aby nagrywać radio."

#: ⁨/home/egon/minu
#: projektid/onair-plasmoid/package/contents/ui/main.qml⁩:4157
msgid "Recording saved ✓ (%1)"
msgstr "Nagranie zapisane ✓ (%1)"

#: ⁨/home/egon/minu
#: projektid/onair-plasmoid/package/contents/ui/main.qml⁩:4161
msgid "Recording interrupted (%1 captured)"
msgstr "Nagranie przerwane (nagrano %1)"

#: ⁨/home/egon/minu
#: projektid/onair-plasmoid/package/contents/ui/main.qml⁩:4163
