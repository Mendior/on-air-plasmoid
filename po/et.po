#: package/contents/ui/main.qml:5030
msgid "yt-dlp is not installed"
msgstr "yt-dlp pole paigaldatud"

#: package/contents/ui/main.qml:5031
msgid "Install yt-dlp (and ffmpeg) to download tracks."
msgstr "Lugude allalaadimiseks paigalda yt-dlp (ja ffmpeg)."

#: package/contents/ui/main.qml:5034
msgid "Track downloaded ✓"
msgstr "Lugu alla laaditud ✓"

#: package/contents/ui/main.qml:5035
msgid "Saved to: %1"
msgstr "Salvestatud: %1"

#: package/contents/ui/main.qml:5038
msgid "Download failed"
msgstr "Allalaadimine ebaõnnestus"

#: package/contents/ui/main.qml:5039
msgid "Unknown error"
msgstr "Tundmatu viga"

#: package/contents/ui/main.qml:5324
msgid "Audio output changed"
msgstr "Heliväljund muutus"

#: package/contents/ui/main.qml:5325
msgid "The chosen output device disappeared — using the system default instead."
msgstr "Valitud väljundseade kadus — kasutusel on süsteemi vaikeväljund."

#: package/contents/ui/MediaListItem.qml:395
msgid "Move up"
msgstr "Liiguta üles"

#: package/contents/ui/MediaListItem.qml:419
msgid "Move down"
msgstr "Liiguta alla"

#: package/contents/ui/MediaListItem.qml:451
msgid "Click again to confirm removal"
msgstr "Eemaldamise kinnitamiseks klõpsa uuesti"

#: package/contents/ui/MediaListItem.qml:452
msgid "Remove station from list"
msgstr "Eemalda jaam nimekirjast"

#: package/contents/ui/SyncEngine.qml:313
msgid "Could not combine the outputs"
msgstr "Väljundite kombineerimine ebaõnnestus"

#: package/contents/ui/SyncEngine.qml:314
msgid "pactl refused to create the combined output."
msgstr "pactl keeldus kombineeritud väljundit loomast."

#: package/contents/ui/SyncEngine.qml:604
msgid "The Bluetooth speaker trails by %1 ms, and every speaker's loudness was matched at the microphone — all set and remembered."
msgstr "Bluetooth-kõlar jääb maha %1 ms ja kõlarite valjus ühtlustati mikrofoni järgi — kõik on seatud ja jäetud meelde."

#: package/contents/ui/SyncEngine.qml:605
msgid "The Bluetooth speaker trails by %1 ms — the delay is set and remembered for this device."
msgstr "Bluetooth-kõlar jääb %1 ms maha — viide on seatud ja jääb sellele seadmele meelde."

#: package/contents/ui/SyncEngine.qml:607
msgid "Balance levels set earlier were replaced by the measured ones."
msgstr "Varem seatud balansitasemed asendati mõõdetud tasemetega."

#: package/contents/ui/SyncEngine.qml:615
msgid "The microphone clipped on %1 — that balance was left unchanged; lower the speaker's volume and calibrate again."
msgstr "Mikrofon läks %1 peal ülevõimendusse — see balanss jäi muutmata; keera kõlari heli vaiksemaks ja kalibreeri uuesti."

#: package/contents/ui/SyncEngine.qml:621
msgid "Measured with %1 — the default microphone stayed silent."
msgstr "Mõõdetud mikrofoniga %1 — vaikimisi mikrofon jäi vait."

#: package/contents/ui/SyncEngine.qml:622
msgid "Speakers calibrated"
msgstr "Kõlarid kalibreeritud"

#: package/contents/ui/SyncEngine.qml:631
#: package/contents/ui/SyncEngine.qml:667
msgid "Calibration did not succeed"
msgstr "Kalibratsioon ei õnnestunud"

#: package/contents/ui/SyncEngine.qml:632
#: package/contents/ui/SyncEngine.qml:779
msgid "Every microphone delivered pure silence. A mic's own mute button is invisible to the system — check the light on the microphone itself, or set a working microphone as the default."
msgstr "Iga mikrofon andis puhast vaikust. Mikrofoni enda vaigistusnupp on süsteemile nähtamatu — kontrolli tulukest mikrofoni peal või sea vaikimisi mikrofoniks töötav mikrofon."

#: package/contents/ui/SyncEngine.qml:654
msgid "Calibration"
msgstr "Kalibratsioon"

#: package/contents/ui/SyncEngine.qml:655
msgid "The clicks were too quiet for this room — trying once more, louder."
msgstr "Klikid jäid selle toa jaoks liiga vaikseks — proovin veel korra, valjemini."

#: package/contents/ui/SyncEngine.qml:668
msgid "Make sure the microphone is not covered and both speakers can be heard, then try again."
msgstr "Veendu, et mikrofon pole kaetud ja mõlemat kõlarit on kuulda, siis proovi uuesti."

#: package/contents/ui/SyncEngine.qml:724
msgid "The speakers were %1 ms apart — adjusted from the measurement, checking once more."
msgstr "Kõlarid olid %1 ms vahega — korrigeerisin mõõtmise järgi, kontrollin veel korra."

#: package/contents/ui/SyncEngine.qml:739
msgid "A speaker's route was stuck %1 ms behind — flushed it, checking once more."
msgstr "Ühe kõlari tee oli %1 ms kinni kiilunud — loputasin selle, kontrollin veel korra."

#: package/contents/ui/SyncEngine.qml:749
#: package/contents/ui/SyncEngine.qml:769
#: package/contents/ui/SyncEngine.qml:778
#: package/contents/ui/SyncEngine.qml:806
#: package/contents/ui/SyncEngine.qml:811
#: package/contents/ui/SyncEngine.qml:818
#: package/contents/ui/SyncEngine.qml:831
msgid "Sync check"
msgstr "Sünki kontroll"

#: package/contents/ui/SyncEngine.qml:770
msgid "The room was not quiet enough to verify — pause other audio and calibrate once more."
msgstr "Tuba ei olnud kontrolliks piisavalt vaikne — peata muu heli ja kalibreeri veel kord."

#: package/contents/ui/SyncEngine.qml:807
msgid "%1 stayed silent through both rounds — it was left out of the group. Tick it back in the speaker list any time."
msgstr "%1 püsis mõlemas voorus vait — see jäeti grupist välja. Linnukesega kõlarite nimekirjas saad ta igal hetkel tagasi."

#: package/contents/ui/SyncEngine.qml:812
msgid "%1 made no sound the microphone could hear. If it stays silent on the next calibration too, it will be left out of the group."
msgstr "%1 ei teinud ühtegi heli, mida mikrofon kuuleks. Kui ta jääb vait ka järgmisel kalibreerimisel, jäetakse ta grupist välja."

#: package/contents/ui/SyncEngine.qml:819
msgid "Could not hear %1 during the check — the speaker may be muted or off. The calibration was kept."
msgstr "Kontrolli ajal ei olnud %1 kuulda — kõlar võib olla vaigistatud või väljas. Kalibratsioon jäi alles."

#: package/contents/ui/SyncEngine.qml:827
msgid "Sync verified"
msgstr "Sünk kinnitatud"

#: package/contents/ui/SyncEngine.qml:828
msgid "Every speaker arrives within %1 ms at the microphone — in step to the ear."
msgstr "Iga kõlar jõuab mikrofonini %1 ms sees — kõrva jaoks ühes taktis."

#: package/contents/ui/SyncEngine.qml:832
msgid "The speakers still arrive %1 ms apart. Calibrate once more, or nudge the delay slider."
msgstr "Kõlarid saabuvad endiselt %1 ms vahega. Kalibreeri veel kord või nihuta viite liugurit."

#: package/contents/ui/SyncEngine.qml:849
msgid "Auto-check %1: too quiet to tell"
msgstr "Autokontroll %1: liiga vaikne, et öelda"

#: package/contents/ui/SyncEngine.qml:855
msgid "Auto-check %1: in sync"
msgstr "Autokontroll %1: sünkis"

#: package/contents/ui/SyncEngine.qml:858
msgid "Auto-check %1: %2 ms apart"
msgstr "Autokontroll %1: %2 ms lahus"

#: package/contents/ui/SyncEngine.qml:878
msgid "Sync has drifted"
msgstr "Sünk on triivinud"

#: package/contents/ui/SyncEngine.qml:879
msgid "The speakers are audibly apart again — run Calibrate when convenient."
msgstr "Kõlarid on taas kuuldavalt lahus — käivita kalibratsioon, kui mahti on."

#: package/contents/ui/SyncEngine.qml:975
msgid "Speaker timing drifted"
msgstr "Kõlari ajastus on triivinud"

#: package/contents/ui/SyncEngine.qml:976
msgid "A Bluetooth speaker came back noticeably off its calibration — the sync compensated automatically. Recalibrate when convenient for exact ears."
msgstr "Bluetooth-kõlar tuli tagasi märgatavalt oma kalibratsioonist väljas — sünk kompenseeris automaatselt. Kalibreeri uuesti, kui mahti on, et kõrv oleks täpne."

#: package/contents/ui/SyncEngine.qml:1790
msgid "Two rounds of clicks with a quiet check between them — about two minutes in total. The music stays silent until the check finishes."
msgstr "Kaks klõpsuvooru, nende vahel vaikne kontroll — kokku umbes kaks minutit. Muusika püsib vait, kuni kontroll lõpeb."

#: package/contents/ui/SyncEngine.qml:1792
msgid "Skipped (empty jack): %1."
msgstr "Vahele jäetud (tühi pesa): %1."

#: package/contents/ui/SyncEngine.qml:1793
msgid "Calibration started"
msgstr "Kalibratsioon algas"

#: package/contents/ui/SyncEngine.qml:1854
msgid "All local outputs (On Air)"
msgstr "Kõik kohalikud väljundid (On Air)"

#: package/contents/ui/SyncEngine.qml:2556
msgid "%1 did not join the sync"
msgstr "%1 ei liitunud sünkrooniga"

#: package/contents/ui/SyncEngine.qml:2558
msgid "The speaker is connected but could not be pulled into the group — switch the sync off and on to rebuild it."
msgstr "Kõlar on ühendatud, aga teda ei õnnestunud gruppi tuua — lülita sünk korraks välja ja uuesti sisse."

#: package/contents/ui/SyncEngine.qml:2559
msgid "The speaker is connected but its audio output never appeared — switch the speaker off and on, then connect it again."
msgstr "Kõlar on ühendatud, aga selle heliväljundit ei tekkinud — lülita kõlar korraks välja ja sisse ning ühenda uuesti."

