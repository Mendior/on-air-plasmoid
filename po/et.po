#: /home/user/on-air-plasmoid/package/contents/ui/FullRepresentation.qml:2402
msgid "Plays on every connected speaker at the same time — wired outputs are delayed to stay in step with Bluetooth."
msgstr "Mängib korraga kõigis ühendatud kõlarites — juhtmega väljundeid viivitatakse, et need püsiksid Bluetoothiga samas taktis."

#: /home/user/on-air-plasmoid/package/contents/ui/FullRepresentation.qml:2416
msgid "Sync fine-tune"
msgstr "Süngi peenhäälestus"

#: /home/user/on-air-plasmoid/package/contents/ui/FullRepresentation.qml:2430
msgid "If the Bluetooth speaker still trails the wired ones, raise this until they play together."
