#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/FullRepresentation.qml:2991
msgid "Sync fine-tune"
msgstr "Süngi peenhäälestus"

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/FullRepresentation.qml:3001
msgid "If the Bluetooth speaker still trails the wired ones, raise this until they play together."
msgstr "Kui Bluetooth-kõlar jääb juhtmega kõlaritest ikka maha, tõsta seda, kuni nad mängivad koos."

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/FullRepresentation.qml:3013
msgid "Sync delay in milliseconds"
msgstr "Sünkroonviive millisekundites"

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/FullRepresentation.qml:3035
msgid "Type an exact delay in milliseconds — the slider moves in steps of ten."
msgstr "Trüki täpne viive millisekundites — liugur liigub kümne kaupa."

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/FullRepresentation.qml:3039
msgid "ms"
msgstr "ms"

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/FullRepresentation.qml:3053
msgid "Calibrate with the microphone"
msgstr "Kalibreeri mikrofoniga"

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/FullRepresentation.qml:3058
msgid "Plays a few loud clicks through each speaker and measures with the microphone how far the Bluetooth speaker trails — the delay is set automatically."
msgstr "Mängib igast kõlarist paar valju klõpsu ja mõõdab mikrofoniga, kui palju Bluetooth-kõlar maha jääb — viide seatakse automaatselt."

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/FullRepresentation.qml:3078
msgid "Round 1 of 2 — clicks through every speaker…"
msgstr "Voor 1/2 — klõpsud läbi iga kõlari…"

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/FullRepresentation.qml:3079
msgid "Round 2 of 2 — quiet, checking the result…"
msgstr "Voor 2/2 — vaikus, kontrollin tulemust…"

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/FullRepresentation.qml:3117
msgid "%1 plays in the group"
msgstr "%1 mängib grupis"

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/FullRepresentation.qml:3130
msgid "Whether this speaker plays in the group — untick to leave it out without disconnecting it. Remembered for the device."
msgstr "Kas see kõlar mängib grupis — eemalda linnuke, et jätta ta mängust välja ilma ühendust katkestamata. Jäetakse seadmele meelde."

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/FullRepresentation.qml:3139
msgid "%1 (nothing plugged in)"
msgstr "%1 (midagi pole ühendatud)"

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/FullRepresentation.qml:3153
msgid "Balance of %1"
msgstr "%1 balanss"

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/FullRepresentation.qml:3162
msgid "This speaker's share of the volume — the balance follows every master move and is remembered for the device. It scales only what this widget plays; the per-device volume in the system's audio settings is a separate, untouched layer — which is why those numbers differ from these sliders."
msgstr "Selle kõlari osa helitugevusest — balanss järgib iga üldnivoo liigutust ja jäetakse seadme jaoks meelde. See mõjutab ainult selle vidina enda heli; süsteemi heliseadete seadmepõhine helitugevus on eraldi, puutumata kiht — seepärast erinevadki sealsed numbrid nendest liuguritest."

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/FullRepresentation.qml:3179
msgctxt "compact: speaker plays the left channel"
msgid "L"
msgstr "L"

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/FullRepresentation.qml:3180
msgctxt "compact: speaker plays the right channel"
msgid "R"
msgstr "R"

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/FullRepresentation.qml:3181
msgctxt "compact: speaker plays a mono mix"
msgid "M"
msgstr "M"

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/FullRepresentation.qml:3182
msgctxt "compact: speaker plays plain stereo"
msgid "ST"
msgstr "ST"

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/FullRepresentation.qml:3187
msgid "Which channels this speaker plays: stereo, left only, right only, or a mono mix of both. Set one speaker to L and another to R for a true stereo pair — remembered for the device."
msgstr "Millised kanalid see kõlar mängib: stereo, ainult vasak, ainult parem või mõlema mono-miks. Pane üks kõlar L-i ja teine R-i peale — saad tõelise stereopaari; jäetakse seadmele meelde."

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/FullRepresentation.qml:3217
msgid "Bluetooth"
msgstr "Bluetooth"

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/FullRepresentation.qml:3232
msgid "Bluetooth is off or no adapter is available — check System Settings."
msgstr "Bluetooth on välja lülitatud või adapterit pole — kontrolli süsteemiseadeid."

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/FullRepresentation.qml:3243
msgid "No paired Bluetooth audio devices — pair the speaker once in System Settings and it appears here."
msgstr "Seotud Bluetooth-heliseadmeid pole — seo kõlar üks kord süsteemiseadetes ja see ilmub siia."

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/FullRepresentation.qml:3257
msgid "%1 — connecting…"
msgstr "%1 — ühendumine…"

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/FullRepresentation.qml:3275
msgid "%1 — pairing…"
msgstr "%1 — seon…"

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/FullRepresentation.qml:3276
msgid "%1 — new, click to pair"
msgstr "%1 — uus, klõpsa sidumiseks"

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/FullRepresentation.qml:3287
msgid "Pair a new speaker…"
msgstr "Seo uus kõlar…"

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/FullRepresentation.qml:3303
msgid "Searching — put the speaker in pairing mode…"
msgstr "Otsin — pane kõlar sidumisrežiimi…"

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/FullRepresentation.qml:3324
msgid "WiFi & network"
msgstr "WiFi ja võrk"

