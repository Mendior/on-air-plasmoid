#: package/contents/ui/config/configAutomation.qml:38
msgid "Never"
msgstr "Mitte kunagi"

#: package/contents/ui/config/configAutomation.qml:39
msgid "Every 6 hours"
msgstr "Iga 6 tunni järel"

#: package/contents/ui/config/configAutomation.qml:40
