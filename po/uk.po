msgstr "Затримка синхронізації в мілісекундах"

#: ⁨/home/egon/minu
#: projektid/onair-plasmoid/package/contents/ui/FullRepresentation.qml⁩:3035
msgid ""
"Type an exact delay in milliseconds — the slider moves in steps of ten."
msgstr ""
"Введіть точну затримку в мілісекундах — повзунок рухається кроками по "
"десять."

#: ⁨/home/egon/minu
#: projektid/onair-plasmoid/package/contents/ui/FullRepresentation.qml⁩:3039
msgid "ms"
msgstr "мс"

#: ⁨/home/egon/minu
#: projektid/onair-plasmoid/package/contents/ui/FullRepresentation.qml⁩:3053
