msgstr "Отримати всі заново"

#: ⁨/home/egon/minu
#: projektid/onair-plasmoid/package/contents/ui/config/configGeneral.qml⁩:1007
msgid ""
"Fetch fresh logos for all stations; existing logos are kept if nothing "
"better is found"
msgstr ""
"Отримати свіжі логотипи для всіх станцій; наявні буде збережено, якщо не "
"знайдеться кращих"

#: ⁨/home/egon/minu
#: projektid/onair-plasmoid/package/contents/ui/config/configGeneral.qml⁩:1022
msgid "Import…"
msgstr "Імпортувати…"

#: ⁨/home/egon/minu
#: projektid/onair-plasmoid/package/contents/ui/config/configGeneral.qml⁩:1028
