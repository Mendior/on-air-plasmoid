msgstr "%1 — файл значно менший, ніж очікувалося."

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:3469
msgid "Recording failed"
msgstr "Не вдалося записати"

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:3470
msgid "The stream could not be captured."
msgstr "Не вдалося захопити потік."

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:3492
msgid "yt-dlp is not installed"
msgstr "yt-dlp не встановлено"

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:3493
msgid "Install yt-dlp (and ffmpeg) to download tracks."
msgstr "Встановіть yt-dlp (і ffmpeg), щоб завантажувати композиції."

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:3496
msgid "Track downloaded ✓"
msgstr "Композицію завантажено ✓"

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:3497
msgid "Saved to: "
msgstr "Збережено до: "

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:3500
msgid "Download failed"
msgstr "Не вдалося завантажити"

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:3501
msgid "Unknown error"
msgstr "Невідома помилка"

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:3736
