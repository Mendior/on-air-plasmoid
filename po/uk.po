msgstr "R"

#: ⁨/home/egon/minu
#: projektid/onair-plasmoid/package/contents/ui/FullRepresentation.qml⁩:3181
msgctxt "compact: speaker plays a mono mix"
msgid "M"
msgstr "M"

#: ⁨/home/egon/minu
#: projektid/onair-plasmoid/package/contents/ui/FullRepresentation.qml⁩:3182
msgctxt "compact: speaker plays plain stereo"
msgid "ST"
msgstr "ST"

#: ⁨/home/egon/minu
#: projektid/onair-plasmoid/package/contents/ui/FullRepresentation.qml⁩:3187
msgid ""
"Which channels this speaker plays: stereo, left only, right only, or a mono "
"mix of both. Set one speaker to L and another to R for a true stereo pair — "
"remembered for the device."
msgstr ""
"Які канали грає ця колонка: стерео, лише лівий, лише правий або моно-мікс "
"обох. Поставте одну колонку на L, а іншу на R — отримаєте справжню "
"стереопару; запам'ятовується для пристрою."

#: ⁨/home/egon/minu
#: projektid/onair-plasmoid/package/contents/ui/FullRepresentation.qml⁩:3217
msgid "Bluetooth"
msgstr "Bluetooth"

#: ⁨/home/egon/minu
#: projektid/onair-plasmoid/package/contents/ui/FullRepresentation.qml⁩:3232
