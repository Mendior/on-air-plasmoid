msgstr "Помилка — переконайтеся, що вибраний каталог доступний для запису!"

#: package/contents/ui/config/configGeneral.qml:1242
msgid "Add…"
msgstr "Додати…"

#: package/contents/ui/config/configGeneral.qml:1251
msgid "Fetching… %1 / %2"
msgstr "Отримання… %1 / %2"

#: package/contents/ui/config/configGeneral.qml:1252
msgid "Fetch missing logos"
msgstr "Отримати відсутні логотипи"

#: package/contents/ui/config/configGeneral.qml:1261
