msgstr "Не вдалося транслювати на %1"

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:3542
msgid "The device could not play this station."
msgstr "Пристрій не зміг відтворити цю станцію."

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:3642
#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:3730
msgid "the Bluetooth device"
msgstr "пристроєм Bluetooth"

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:3641
msgid "Could not connect to %1"
msgstr "Не вдалося з'єднатися з %1"

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:3643
