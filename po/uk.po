#: projektid/onair-plasmoid/package/contents/ui/FullRepresentation.qml⁩:3179
msgctxt "compact: speaker plays the left channel"
msgid "L"
msgstr "L"

#: ⁨/home/egon/minu
#: projektid/onair-plasmoid/package/contents/ui/FullRepresentation.qml⁩:3180
msgctxt "compact: speaker plays the right channel"
