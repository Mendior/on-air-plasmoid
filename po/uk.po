msgstr "Не вдалося спарувати з %1"

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:3365
msgid "Put the speaker in pairing mode (hold its Bluetooth button) and try again."
msgstr "Переведіть колонку в режим спарювання (утримуйте кнопку Bluetooth) і спробуйте ще раз."

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:3455
msgid "ffmpeg is not installed"
msgstr "ffmpeg не встановлено"

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:3456
msgid "Install ffmpeg to record radio."
msgstr "Встановіть ffmpeg, щоб записувати радіо."

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:3459
