msgstr "Пристрій не зміг відтворити цю станцію."

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:3290
#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:3364
msgid "the Bluetooth device"
msgstr "пристроєм Bluetooth"

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:3289
