msgstr "%1 min"

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/config/configRecording.qml:57
msgid "A hard safety cap for one recording — protects the disk if you forget to stop."
msgstr "Limite rígido de segurança para uma gravação — protege o disco se você esquecer de parar."

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/config/configRecording.qml:69
