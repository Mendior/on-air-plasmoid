#: package/contents/ui/main.qml:3355
msgid "Turn the speaker off and on again, then reconnect it."
msgstr "Desligue e ligue a caixa de som novamente e reconecte-a."

#: package/contents/ui/main.qml:3744
msgid "Station seems to be off the air"
msgstr "A estação parece estar fora do ar"

#: package/contents/ui/main.qml:3745
msgid ""
"%1 is not answering at any address the directory knows. It stays in your "
"list — trying again in the background."
msgstr ""
"%1 não responde em nenhum endereço conhecido pelo diretório. Ela continua na"
" sua lista — tentando de novo em segundo plano."

#: package/contents/ui/main.qml:3817
msgid "Playing from a backup address"
msgstr "Tocando de um endereço reserva"

#: package/contents/ui/main.qml:3818
msgid ""
"The station's saved address is not answering — playing the directory's "
"closest match for now. Your saved address was kept."
msgstr ""
"O endereço salvo da estação não responde — por enquanto toca a "
"correspondência mais próxima do diretório. Seu endereço salvo foi mantido."

#: package/contents/ui/main.qml:3858
msgid "Station found at a new address"
msgstr "Estação encontrada em um novo endereço"

#: package/contents/ui/main.qml:3859
msgid "%1 moved — the new address was saved to your list."
msgstr "%1 se mudou — o novo endereço foi salvo na sua lista."

#: package/contents/ui/main.qml:5100
msgid "Episode downloaded"
msgstr "Episódio baixado"

#: package/contents/ui/main.qml:5104
msgid "Episode download failed"
msgstr "Falha ao baixar o episódio"

#: package/contents/ui/main.qml:5194
msgid "Casting needs python-chromecast"
msgstr "A transmissão precisa do python-chromecast"

#: package/contents/ui/main.qml:5195
msgid "Install the python-chromecast package to cast to your devices."
msgstr ""
"Instale o pacote python-chromecast para transmitir para seus dispositivos."

#: package/contents/ui/main.qml:5216
msgid "the device"
msgstr "o dispositivo"

#: package/contents/ui/main.qml:5216
msgid "Could not cast to %1"
msgstr "Não foi possível transmitir para %1"

#: package/contents/ui/main.qml:5217
msgid "The device could not play this station."
msgstr "O dispositivo não conseguiu reproduzir esta estação."

#: package/contents/ui/main.qml:5263
msgid "Casting"
msgstr "Transmitindo"

#: package/contents/ui/main.qml:5264
msgid "The device did not stop — it may still be playing."
msgstr "O dispositivo não parou — pode ainda estar reproduzindo."

#: package/contents/ui/main.qml:5320 package/contents/ui/main.qml:5422
msgid "the Bluetooth device"
msgstr "o dispositivo Bluetooth"

#: package/contents/ui/main.qml:5319
msgid "Could not connect to %1"
msgstr "Não foi possível conectar a %1"

#: package/contents/ui/main.qml:5321
msgid "Make sure the speaker is switched on and in range."
msgstr "Verifique se o alto-falante está ligado e dentro do alcance."

#: package/contents/ui/main.qml:5421
msgid "Could not pair with %1"
msgstr "Não foi possível parear com %1"

#: package/contents/ui/main.qml:5423
msgid ""
"Put the speaker in pairing mode (hold its Bluetooth button) and try again."
msgstr ""
"Coloque a caixa em modo de pareamento (segure o botão Bluetooth) e tente "
"novamente."

#: package/contents/ui/main.qml:5521
msgid "ffmpeg is not installed"
msgstr "O ffmpeg não está instalado"

#: package/contents/ui/main.qml:5522
msgid "Install ffmpeg to record radio."
msgstr "Instale o ffmpeg para gravar rádio."

#: package/contents/ui/main.qml:5525
msgid "Not enough disk space for this recording"
msgstr "Espaço em disco insuficiente para esta gravação"

#: package/contents/ui/main.qml:5526
msgid "Free some space in %1 and try again."
msgstr "Libere espaço em %1 e tente novamente."

#: package/contents/ui/main.qml:5529
msgid "Recording saved ✓ (%1)"
msgstr "Gravação salva ✓ (%1)"

#: package/contents/ui/main.qml:5533
msgid "Recording interrupted (%1 captured)"
msgstr "Gravação interrompida (%1 capturado)"

#: package/contents/ui/main.qml:5535
msgid "%1 — the file is much smaller than expected."
msgstr "%1 — o arquivo é muito menor que o esperado."

#: package/contents/ui/main.qml:5539
msgid "Recording failed"
msgstr "Falha na gravação"

#: package/contents/ui/main.qml:5540
msgid "The stream could not be captured."
msgstr "Não foi possível capturar a transmissão."

#: package/contents/ui/main.qml:5626
msgid "Downloading again without the cover"
msgstr "Baixando de novo sem a capa"

#: package/contents/ui/main.qml:5627
msgid ""
"Embedding tags needs the python-mutagen package — install it to get covers "
"in your files."
msgstr ""
"Incorporar as tags exige o pacote python-mutagen — instale-o para ter capas "
"nos seus arquivos."

#: package/contents/ui/main.qml:5635
msgid "yt-dlp is not installed"
msgstr "O yt-dlp não está instalado"

#: package/contents/ui/main.qml:5636
msgid "Install yt-dlp (and ffmpeg) to download tracks."
msgstr "Instale o yt-dlp (e o ffmpeg) para baixar faixas."

#: package/contents/ui/main.qml:5639
msgid "Track downloaded ✓"
msgstr "Faixa baixada ✓"

#: package/contents/ui/main.qml:5640
msgid "Saved to: %1"
msgstr "Salvo em: %1"

#: package/contents/ui/main.qml:5643
msgid "Download failed"
msgstr "Falha no download"

#: package/contents/ui/main.qml:5644
msgid "Unknown error"
msgstr "Erro desconhecido"

#: package/contents/ui/main.qml:5941
msgid "Audio output changed"
msgstr "Saída de áudio alterada"

#: package/contents/ui/main.qml:5942
msgid ""
"The chosen output device disappeared — using the system default instead."
msgstr ""
"O dispositivo de saída escolhido desapareceu — usando a saída padrão do "
"sistema."

#: package/contents/ui/MediaListItem.qml:472
msgid "Move up"
msgstr "Mover para cima"

#: package/contents/ui/MediaListItem.qml:493
msgid "Move down"
msgstr "Mover para baixo"

#: package/contents/ui/MediaListItem.qml:522
msgid "Click again to confirm removal"
msgstr "Clique novamente para confirmar a remoção"

#: package/contents/ui/MediaListItem.qml:523
msgid "Remove station from list"
msgstr "Remover a estação da lista"

#: package/contents/ui/SyncEngine.qml:313
msgid "Could not combine the outputs"
msgstr "Não foi possível combinar as saídas"

#: package/contents/ui/SyncEngine.qml:314
msgid "pactl refused to create the combined output."
msgstr "O pactl recusou-se a criar a saída combinada."

#: package/contents/ui/SyncEngine.qml:604
msgid ""
"The Bluetooth speaker trails by %1 ms, and every speaker's loudness was "
"matched at the microphone — all set and remembered."
msgstr ""
"A caixa de som Bluetooth está %1 ms atrasada, e o volume de todas as caixas "
"foi igualado no microfone — tudo ajustado e memorizado."

#: package/contents/ui/SyncEngine.qml:605
msgid ""
"The Bluetooth speaker trails by %1 ms — the delay is set and remembered for "
"this device."
msgstr ""
"A caixa Bluetooth atrasa %1 ms — o atraso foi definido e memorizado para "
"este dispositivo."

#: package/contents/ui/SyncEngine.qml:607
msgid "Balance levels set earlier were replaced by the measured ones."
msgstr ""
"Os níveis de balanço definidos antes foram substituídos pelos medidos."

#: package/contents/ui/SyncEngine.qml:615
msgid ""
"The microphone clipped on %1 — that balance was left unchanged; lower the "
"speaker's volume and calibrate again."
msgstr ""
"O microfone saturou em %1 — esse balanço ficou inalterado; reduza o volume "
"da caixa e calibre novamente."

#: package/contents/ui/SyncEngine.qml:621
msgid "Measured with %1 — the default microphone stayed silent."
msgstr "Medido com %1 — o microfone padrão ficou em silêncio."

#: package/contents/ui/SyncEngine.qml:622
msgid "Speakers calibrated"
msgstr "Caixas calibradas"

#: package/contents/ui/SyncEngine.qml:631
#: package/contents/ui/SyncEngine.qml:667
msgid "Calibration did not succeed"
msgstr "A calibração não teve êxito"

#: package/contents/ui/SyncEngine.qml:632
#: package/contents/ui/SyncEngine.qml:779
msgid ""
"Every microphone delivered pure silence. A mic's own mute button is "
"invisible to the system — check the light on the microphone itself, or set a"
" working microphone as the default."
msgstr ""
"Todos os microfones entregaram puro silêncio. O botão de mudo do próprio "
"microfone é invisível para o sistema — verifique a luz no microfone ou "
"defina um microfone que funcione como padrão."

#: package/contents/ui/SyncEngine.qml:654
msgid "Calibration"
msgstr "Calibração"

#: package/contents/ui/SyncEngine.qml:655
msgid "The clicks were too quiet for this room — trying once more, louder."
msgstr ""
"Os cliques ficaram fracos demais para esta sala — mais uma tentativa, mais "
"alto."

#: package/contents/ui/SyncEngine.qml:668
msgid ""
"Make sure the microphone is not covered and both speakers can be heard, then"
" try again."
msgstr ""
"Verifique se o microfone não está coberto e se as duas caixas podem ser "
"ouvidas, depois tente de novo."

#: package/contents/ui/SyncEngine.qml:724
msgid ""
"The speakers were %1 ms apart — adjusted from the measurement, checking once"
" more."
msgstr ""
"As caixas estavam %1 ms afastadas — ajustado pela medição, verificando mais "
"uma vez."

#: package/contents/ui/SyncEngine.qml:739
msgid ""
"A speaker's route was stuck %1 ms behind — flushed it, checking once more."
msgstr ""
"A rota de uma caixa ficou presa %1 ms atrás — esvaziada, verificando mais "
"uma vez."

#: package/contents/ui/SyncEngine.qml:749
#: package/contents/ui/SyncEngine.qml:769
#: package/contents/ui/SyncEngine.qml:778
#: package/contents/ui/SyncEngine.qml:806
#: package/contents/ui/SyncEngine.qml:811
#: package/contents/ui/SyncEngine.qml:818
#: package/contents/ui/SyncEngine.qml:831
#: package/contents/ui/SyncEngine.qml:902
msgid "Sync check"
msgstr "Verificação de sincronização"

#: package/contents/ui/SyncEngine.qml:770
msgid ""
"The room was not quiet enough to verify — pause other audio and calibrate "
"once more."
msgstr ""
"O ambiente não estava silencioso o bastante para verificar — pause outros "
"áudios e calibre mais uma vez."

#: package/contents/ui/SyncEngine.qml:807
msgid ""
"%1 stayed silent through both rounds — it was left out of the group. Tick it"
" back in the speaker list any time."
msgstr ""
"%1 ficou em silêncio nas duas rodadas — foi deixado fora do grupo. Marque-o "
"na lista de alto-falantes quando quiser."

#: package/contents/ui/SyncEngine.qml:812
msgid ""
"%1 made no sound the microphone could hear. If it stays silent on the next "
"calibration too, it will be left out of the group."
msgstr ""
"%1 não fez nenhum som que o microfone pudesse ouvir. Se continuar em "
"silêncio também na próxima calibração, ficará fora do grupo."

#: package/contents/ui/SyncEngine.qml:819
msgid ""
"Could not hear %1 during the check — the speaker may be muted or off. The "
"calibration was kept."
msgstr ""
"%1 não foi ouvido durante a verificação — a caixa pode estar muda ou "
"desligada. A calibração foi mantida."

#: package/contents/ui/SyncEngine.qml:827
msgid "Sync verified"
msgstr "Sincronização verificada"

#: package/contents/ui/SyncEngine.qml:828
msgid ""
"Every speaker arrives within %1 ms at the microphone — in step to the ear."
msgstr ""
"Cada caixa chega ao microfone dentro de %1 ms — em sintonia para o ouvido."

#: package/contents/ui/SyncEngine.qml:832
msgid ""
"The speakers still arrive %1 ms apart. Calibrate once more, or nudge the "
"delay slider."
msgstr ""
"As caixas ainda chegam com %1 ms de diferença. Calibre mais uma vez ou "
"ajuste o controle de atraso."

#: package/contents/ui/SyncEngine.qml:862
msgid "Auto-check %1: too quiet to tell"
msgstr "Verificação automática %1: silencioso demais para dizer"

#: package/contents/ui/SyncEngine.qml:868
msgid "Auto-check %1: in sync"
msgstr "Verificação automática %1: em sincronia"

#: package/contents/ui/SyncEngine.qml:871
msgid "Auto-check %1: %2 ms apart"
msgstr "Verificação automática %1: %2 ms de diferença"

#: package/contents/ui/SyncEngine.qml:903
msgid "Speakers drifted — checking sync. Music pauses for about a minute."
msgstr ""
"As caixas de som desalinharam — verificando a sincronização. A música pausa "
"por cerca de um minuto."

#: package/contents/ui/SyncEngine.qml:907
msgid "Sync has drifted"
msgstr "A sincronização desviou"

#: package/contents/ui/SyncEngine.qml:908
msgid "The speakers are audibly apart again — run Calibrate when convenient."
msgstr ""
"As caixas de som estão audivelmente desalinhadas de novo — execute a "
"calibração quando for conveniente."

#: package/contents/ui/SyncEngine.qml:1004
msgid "Speaker timing drifted"
msgstr "O tempo da caixa de som desviou"

#: package/contents/ui/SyncEngine.qml:1005
msgid ""
"A Bluetooth speaker came back noticeably off its calibration — the sync "
"compensated automatically. Recalibrate when convenient for exact ears."
msgstr ""
"Uma caixa de som Bluetooth voltou visivelmente fora da calibração — a "
"sincronização compensou automaticamente. Recalibre quando for conveniente "
"para ouvidos exatos."

#: package/contents/ui/SyncEngine.qml:1824
msgid ""
"Two rounds of clicks with a quiet check between them — about two minutes in "
"total. The music stays silent until the check finishes."
msgstr ""
"Duas rodadas de cliques com uma checagem silenciosa entre elas — cerca de "
"dois minutos no total. A música fica em silêncio até a checagem terminar."

#: package/contents/ui/SyncEngine.qml:1826
msgid "Skipped (empty jack): %1."
msgstr "Ignorado (conector vazio): %1."

#: package/contents/ui/SyncEngine.qml:1827
msgid "Calibration started"
msgstr "Calibração iniciada"

#: package/contents/ui/SyncEngine.qml:1888
msgid "All local outputs (On Air)"
msgstr "Todas as saídas locais (On Air)"

#: package/contents/ui/SyncEngine.qml:2650
msgid "%1 did not join the sync"
msgstr "%1 não entrou na sincronização"

#: package/contents/ui/SyncEngine.qml:2652
msgid ""
"The speaker is connected but could not be pulled into the group — switch the"
" sync off and on to rebuild it."
msgstr ""
"A caixa de som está conectada, mas não foi possível trazê-la para o grupo — "
"desligue e ligue a sincronização novamente."

#: package/contents/ui/SyncEngine.qml:2653
msgid ""
"The speaker is connected but its audio output never appeared — switch the "
"speaker off and on, then connect it again."
msgstr ""
"A caixa de som está conectada, mas a saída de áudio dela nunca apareceu — "
"desligue e ligue a caixa de som e conecte-a novamente."

