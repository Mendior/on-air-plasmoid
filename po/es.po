msgstr "Escribe un retardo exacto en milisegundos — el deslizador se mueve en pasos de diez."

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/FullRepresentation.qml:3030
msgid "ms"
msgstr "ms"

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/FullRepresentation.qml:3044
