msgstr "ffmpeg ist nicht installiert"

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:3708
msgid "Install ffmpeg to record radio."
msgstr "Installieren Sie ffmpeg, um Radio aufzunehmen."

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:3711
msgid "Recording saved ✓ (%1)"
msgstr "Aufnahme gespeichert ✓ (%1)"

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:3715
msgid "Recording interrupted (%1 captured)"
msgstr "Aufnahme unterbrochen (%1 aufgenommen)"

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:3717
msgid "%1 — the file is much smaller than expected."
msgstr "%1 — die Datei ist viel kleiner als erwartet."

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:3721
msgid "Recording failed"
msgstr "Aufnahme fehlgeschlagen"

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:3722
msgid "The stream could not be captured."
msgstr "Der Stream konnte nicht aufgenommen werden."

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:3752
msgid "Downloading again without the cover"
msgstr "Erneuter Download ohne Cover"

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:3753
msgid "Embedding tags needs the python-mutagen package — install it to get covers in your files."
msgstr "Zum Einbetten der Metadaten wird das Paket python-mutagen benötigt — installieren Sie es, um Cover in den Dateien zu erhalten."

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:3761
msgid "yt-dlp is not installed"
msgstr "yt-dlp ist nicht installiert"

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:3762
msgid "Install yt-dlp (and ffmpeg) to download tracks."
msgstr "Installieren Sie yt-dlp (und ffmpeg), um Titel herunterzuladen."

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:3765
msgid "Track downloaded ✓"
msgstr "Titel heruntergeladen ✓"

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:3766
msgid "Saved to: %1"
msgstr "Gespeichert unter: %1"

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:3769
msgid "Download failed"
msgstr "Download fehlgeschlagen"

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:3770
