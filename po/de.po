msgstr "Das Gerät konnte diesen Sender nicht abspielen."

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:3543
#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:3616
msgid "the Bluetooth device"
msgstr "das Bluetooth-Gerät"

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:3542
msgid "Could not connect to %1"
msgstr "Verbindung mit %1 nicht möglich"

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:3544
msgid "Make sure the speaker is switched on and in range."
msgstr "Stellen Sie sicher, dass der Lautsprecher eingeschaltet und in Reichweite ist."

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:3615
