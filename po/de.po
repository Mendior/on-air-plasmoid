msgstr "Sender unter neuer Adresse gefunden"

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:2444
msgid "%1 moved — the new address was saved to your list."
msgstr "%1 ist umgezogen — die neue Adresse wurde in deiner Liste gespeichert."

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/main.qml:3497
