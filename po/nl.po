msgid "The speakers were %1 ms apart — adjusted from the measurement, checking once more."
msgstr "De luidsprekers zaten %1 ms uit elkaar — bijgesteld op basis van de meting, wordt nogmaals gecontroleerd."

#: package/contents/ui/SyncEngine.qml:746
msgid "A speaker's route was stuck %1 ms behind — flushed it, checking once more."
msgstr "De route van een luidspreker zat %1 ms vast — doorgespoeld, wordt nogmaals gecontroleerd."

#: package/contents/ui/SyncEngine.qml:756
#: package/contents/ui/SyncEngine.qml:776
#: package/contents/ui/SyncEngine.qml:785
#: package/contents/ui/SyncEngine.qml:813
#: package/contents/ui/SyncEngine.qml:818
#: package/contents/ui/SyncEngine.qml:825
#: package/contents/ui/SyncEngine.qml:838
#: package/contents/ui/SyncEngine.qml:909
