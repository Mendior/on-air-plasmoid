msgstr "Overgeslagen (lege aansluiting): %1."

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/SyncEngine.qml:1164
msgid "Calibration started"
msgstr "Kalibratie gestart"

#: /home/egon/Projects/on-air-plasmoid/package/contents/ui/SyncEngine.qml:1214
